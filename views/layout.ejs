<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/products">Gestion Produits</a>
  </nav>

  <div class="container mt-4">

    <% if (flashMessage) { %>
      <div class="alert alert-<%= flashMessage.type === 'success' ? 'success' : 'danger' %>">
        <%= flashMessage.text %>
      </div>
    <% } %>

    <%- body %>

  </div>

  <footer class="text-center mt-5 mb-3">
    © 2026 Application CRUD avec Express & MongoDB
  </footer>

</body>
</html>